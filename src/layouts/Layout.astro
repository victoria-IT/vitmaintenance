---
import "../styles/global.css";
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Victoria IT is currently down for maintenance to serve you better. Please check back soon for improved services and enhanced features. Thank you for your patience." />
    <meta name="keywords" content="Victoria IT, maintenance, website down, coming soon" />
    <meta name="author" content="Victoria IT" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script>
      // Set robots meta tag based on domain
      var meta = document.createElement('meta');
      meta.name = 'robots';
      if (window.location.hostname.includes('pages.dev')) {
        meta.content = 'noindex, nofollow';
      } else {
        meta.content = 'index, follow';
      }
      document.head.appendChild(meta);
    </script>
    <script async src="https://cdn.amplitude.com/script/8b7081514100ce1fa1e32e1eba52ce3b.js"></script>
  <body class="bg-white font-SpaceGrotesk min-h-screen flex flex-col">
    <Navbar />
    <div class="flex-1 flex flex-col">
      <slot />
    </div>
    <Footer/>
    <script>
      // Cookie consent
      document.addEventListener('DOMContentLoaded', function() {
        // Check if cookies are already set
        if (!document.cookie.includes('cookie_prefs=')) {
          // Create modal (hidden initially)
          var modal = document.createElement('div');
          modal.id = 'cookie-modal';
          modal.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:10000;display:none;align-items:center;justify-content:center;';
          modal.innerHTML = `
            <div style="background:#fff;color:#191A23;padding:24px;border-radius:12px;max-width:600px;width:90%;text-align:left;">
              <h3 style="margin-bottom:16px;font-size:18px;font-weight:bold;">Cookie Preferences</h3>
              <div style="margin-bottom:12px;">
                <label style="display:flex;align-items:center;">
                  <input type="checkbox" id="necessary" checked disabled style="margin-right:8px;">
                  <span>Necessary Cookies (Always enabled)</span>
                </label>
              </div>
              <div style="margin-bottom:12px;">
                <label style="display:flex;align-items:center;">
                  <input type="checkbox" id="performance" style="margin-right:8px;">
                  <span>Performance Cookies</span>
                </label>
              </div>
              <div style="margin-bottom:12px;">
                <label style="display:flex;align-items:center;">
                  <input type="checkbox" id="functional" style="margin-right:8px;">
                  <span>Functional Cookies</span>
                </label>
              </div>
              <div style="margin-bottom:20px;">
                <label style="display:flex;align-items:center;">
                  <input type="checkbox" id="advertising" style="margin-right:8px;">
                  <span>Advertising Cookies</span>
                </label>
              </div>
              <div style="display:flex;justify-content:space-around;gap:10px;">
                <button id="save-prefs" style="background:#B9FF66;color:#191A23;padding:8px 16px;border:none;border-radius:8px;font-weight:bold;cursor:pointer;flex:1;">Save Preferences</button>
                <button id="accept-all-modal" style="background:#B9FF66;color:#191A23;padding:8px 16px;border:none;border-radius:8px;font-weight:bold;cursor:pointer;flex:1;">Accept All</button>
                <button id="decline-all-modal" style="background:#fff;color:#191A23;padding:8px 16px;border:1px solid #B9FF66;border-radius:8px;font-weight:bold;cursor:pointer;flex:1;">Decline All</button>
              </div>
            </div>
          `;
          document.body.appendChild(modal);

          // Create banner
          var banner = document.createElement('div');
          banner.style.cssText = 'position:fixed;bottom:0;left:0;width:100%;background:#191A23;color:#fff;z-index:9999;padding:16px;text-align:center;';
          banner.innerHTML = '<span style="margin-right:16px;">We use cookies to enhance your experience. <a href="/privacy-policy" style="color:#B9FF66;text-decoration:underline;">Privacy Policy</a></span>' +
            '<button id="accept-all" style="background:#B9FF66;color:#191A23;padding:8px 18px;border:none;border-radius:8px;font-weight:bold;cursor:pointer;margin-right:8px;">Accept All</button>' +
            '<button id="settings" style="background:#fff;color:#191A23;padding:8px 18px;border:1px solid #B9FF66;border-radius:8px;font-weight:bold;cursor:pointer;margin-right:8px;">Settings</button>' +
            '<button id="decline-all" style="background:#fff;color:#191A23;padding:8px 18px;border:1px solid #B9FF66;border-radius:8px;font-weight:bold;cursor:pointer;">Decline All</button>';
          
          document.body.appendChild(banner);
          
          // Helper function to set cookie
          function setCookiePrefs(necessary: boolean, performance: boolean, functional: boolean, advertising: boolean) {
            document.cookie = `cookie_prefs=necessary:${necessary},performance:${performance},functional:${functional},advertising:${advertising};path=/;max-age=31536000`;
            banner.remove();
            modal.style.display = 'none';
          }
          
          // Accept All button
          var acceptBtn = document.getElementById('accept-all') as HTMLButtonElement | null;
          if (acceptBtn) {
            acceptBtn.onclick = function() {
              setCookiePrefs(true, true, true, true);
            };
          }
          
          // Settings button
          var settingsBtn = document.getElementById('settings') as HTMLButtonElement | null;
          if (settingsBtn) {
            settingsBtn.onclick = function() {
              modal.style.display = 'flex';
            };
          }
          
          // Decline All button
          var declineBtn = document.getElementById('decline-all') as HTMLButtonElement | null;
          if (declineBtn) {
            declineBtn.onclick = function() {
              setCookiePrefs(true, false, false, false);
            };
          }
          
          // Modal buttons
          var saveBtn = document.getElementById('save-prefs') as HTMLButtonElement | null;
          if (saveBtn) {
            saveBtn.onclick = function() {
              var performance = (document.getElementById('performance') as HTMLInputElement).checked;
              var functional = (document.getElementById('functional') as HTMLInputElement).checked;
              var advertising = (document.getElementById('advertising') as HTMLInputElement).checked;
              setCookiePrefs(true, performance, functional, advertising);
            };
          }
          
          var acceptAllModal = document.getElementById('accept-all-modal') as HTMLButtonElement | null;
          if (acceptAllModal) {
            acceptAllModal.onclick = function() {
              setCookiePrefs(true, true, true, true);
            };
          }
          
          var declineAllModal = document.getElementById('decline-all-modal') as HTMLButtonElement | null;
          if (declineAllModal) {
            declineAllModal.onclick = function() {
              setCookiePrefs(true, false, false, false);
            };
          }
          
          // Close modal on outside click
          modal.onclick = function(e) {
            if (e.target === modal) {
              modal.style.display = 'none';
            }
          };
        }
      });
      
      // Track button clicks (placeholder for future analytics)
      document.addEventListener('click', function(e) {
        var target = e.target as HTMLElement;
        if (target && target.tagName === 'A' && target instanceof HTMLAnchorElement && target.href && target.href.includes('tel:')) {
          // Future analytics tracking
          console.log('Call button clicked');
        }
      });
    </script>
  </body>
</html>
